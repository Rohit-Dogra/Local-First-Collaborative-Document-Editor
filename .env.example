# Database — Supabase
# Local dev / db:seed: Direct connection (port 5432)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Netlify/serverless: use Supabase Transaction pooler (port 6543) in Netlify env vars:
# postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://your-app-name.netlify.app"

# AI (optional - grammar check, summarize, improve writing)
OPENAI_API_KEY="sk-..."
